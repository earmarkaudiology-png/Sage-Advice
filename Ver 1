    body += '<div style="margin-top:6px;"><b>Sages</b></div>';
    body += allSages().length ? _.map(_.sortBy(allSages(), function (s) { return (s.name || '').toLowerCase(); }), function (s) {
        var parts = [];
        var statusNotes = [];
        parts.push('<div style="margin-left:8px;margin-bottom:8px;">');
        parts.push('<b>' + esc(s.name) + '</b> — ' + esc(labelForField(s.majorField)) + ' — ' + esc(employmentLabel(s)));
        parts.push('<br><span style="color:' + CONFIG.colors.subtext + ';">' + esc(sageKnowledgeSummary(s)) + '</span>');
        if (s.shortTerm) {
            statusNotes.push('Short-Term Employer: ' + s.shortTerm.employerName + ' (' + shortTermDaysRemainingDisplay(s) + ' day(s) remaining)');
        }
        if (sageIsResting(s)) {
            statusNotes.push('Resting: ' + sageRestDaysRemaining(s) + ' more day(s)');
        } else if ((Number(s.cooldownUntilDay) || 0) > state[STATE].currentDay) {
            statusNotes.push('Resting: ' + sageRestDaysRemaining(s) + ' more day(s)');
        }
        if (s.employment === 'permanent' && s.ownerId) {
            var owner = getObj('character', s.ownerId);
            statusNotes.push('Permanent Employer: ' + (owner ? owner.get('name') : 'another character'));
        }
        if (statusNotes.length) parts.push('<br><span style="color:' + CONFIG.colors.subtext + ';">' + esc(statusNotes.join(' | ')) + '</span>');
        if (includeActions) {
            var actionButtons = reportActionButtonsForSage(s, employer);
            if (actionButtons) parts.push('<div style="margin-top:4px;">' + actionButtons + '</div>');
        }
        parts.push('</div>');
        return parts.join('');
    }).join('') : '<div style="margin-left:8px;">none</div>';
    return body;
}

