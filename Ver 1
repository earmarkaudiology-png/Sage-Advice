    function efficiencyFromMaterials(materialsGp) {
        materialsGp = Number(materialsGp) || 0;
        if (materialsGp < 20000) return 0;
        if (materialsGp <= 60000) {
            return Math.min(90, 50 + Math.floor((materialsGp - 20000) / 1000));
        }
        return Math.min(100, 90 + Math.floor((materialsGp - 60000) / 4000));
    }

