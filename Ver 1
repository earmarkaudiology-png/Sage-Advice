    function handleAsk(msg, args) {
    var employer = resolveEmployer(msg, args);
    var sage = getSageById(args.sage);
    var q;
    var extensionDays;
    var extensionQuote;
    if (!employer || !sage) {
        send(box('Ask Sage Question', 'Employer or sage not found.' + backMenuButton(employer ? employer.id : '')));
        return;
    }
    if (activePcResearchForEmployer(employer)) {
        send(box('Ask Sage Question', '<div>' + esc(blockedByPcResearchText(employer)) + '</div>' + backMenuButton(employer.id)));
        return;
    }
    if (sage.activeStudy) {
        send(box('Ask Sage Question', '<div>This sage is in uninterrupted study and cannot be questioned.</div>' + backMenuButton(employer.id)));
        return;
    }
    if (sage.employment === 'permanent') {
        if (sage.ownerId !== employer.id) {
            send(box('Ask Sage Question', '<div>This sage is permanently employed by another character.</div>' + backMenuButton(employer.id)));
            return;
        }
    } else {
        if (!sage.shortTerm || sage.shortTerm.employerId !== employer.id) {
            send(box('Ask Sage Question', '<div>Hire this sage short-term first.</div>' + backMenuButton(employer.id)));
            return;
        }
        if (!employerCanConsultSageNow(employer, sage)) {
            finishShortTermIfIdle(sage);
            send(box('Ask Sage Question', '<div>This short-term hire has run out of paid time. The rest period starts after any question already in progress is completed.</div>' + backMenuButton(employer.id)));
            return;
        }
    }

    if (sageIsResting(sage) && normalizeNatureKey(args.nature) !== 'general') {
        send(box('Ask Sage Question',
            line('Sage', esc(sage.name)) +
            '<div>' + esc(sageRestMessage(sage)) + '</div>' +
            backMenuButton(employer.id)
        ));
        return;
    }

    q = createQuestionRecord(employer, sage, args);
    if (q.error) {
        send(box('Ask Sage Question', '<div>' + esc(q.error) + '</div>' + backMenuButton(employer.id)));
        return;
    }

    if (q.employmentType === 'shortterm' && q.timeUnit === 'days' && q.readyDay > (Number(sage.shortTerm.paidThroughDay) || 0)) {
        allQuestions().push(q);
        q.status = 'extensionquote';
        extensionDays = Math.max(7, Math.ceil((q.readyDay - (Number(sage.shortTerm.paidThroughDay) || 0)) / 7) * 7);
        extensionQuote = buildHireQuote(employer, sage, 'extension', {
            days: extensionDays,
            currentCostGp: CONFIG.shortTermBaseGpPerDay * extensionDays,
            linkedQuestionId: q.id
        });
        allHireQuotes().push(extensionQuote);
        renderHireQuote(extensionQuote, employer,
            'This question needs more time than remains on the current short-term hire. An additional block of paid time is required before the sage can continue.');
        return;
    }

    allQuestions().push(q);
    if (q.employmentType === 'shortterm' && sage.shortTerm && !_.contains(sage.shortTerm.questionIds, q.id)) sage.shortTerm.questionIds.push(q.id);
    updateCharacterForSage(sage);

    if (q.status === 'quote') {
        send(box('Sage Question Quote',
            line('Employer', esc(employerName(employer))) +
            line('Sage', esc(sage.name)) +
            line('Question', esc(q.question)) +
            line('Field Relation', esc(fieldRelationLabel(q.relation))) +
            line('Question Type', esc(natureLabel(q.nature))) +
            line('Time Frame', esc(questionBroadTimeFrameLabel(q))) +
            line('Quoted Cost', esc(q.currentCostGp + ' gp')) +
            (q.remote ? line('Remote Research', 'Yes — time and variable cost doubled') : '') +
            '<div style="margin-top:6px;">This is the DMG variable research charge for the question. The daily short-term hire fee is already separate.</div>' +
            '<div style="margin-top:8px;">' +
                menuBtn('Accept Quote / Pay', '!sage-accept-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 140) +
                (!(q.haggleDone || (q.haggleAttempts || 0) >= 2) ? menuBtn('Haggle Price', '!sage-haggle-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) : '') +
                menuBtn('Deny Quote', '!sage-deny-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 100) +
            '</div>' +
            backMenuButton(employer.id)
        ));
        return;
    }

    if (q.status === 'ready') {
        var readyNowBtn = (playerIsGM(msg.playerid) && employerCanCollectReadyAnswer(employer, sage, q))
            ? '<div style="margin-top:8px;">' + menuBtn('Answer Now', '!sage-set-answer --pc|' + employer.id + ' --question|' + q.id + ' --text|?{GM answer text|}', CONFIG.colors.gmBg, CONFIG.colors.gmBorder, 95) + '</div>'
            : '';
        send(box('Sage Question Ready',
            line('Employer', esc(employerName(employer))) +
            line('Sage', esc(sage.name)) +
            line('Question', esc(q.question)) +
            line('Time Frame', esc(questionBroadTimeFrameLabel(q))) +
            '<div style="margin-top:6px;">The sage is ready to give the answer to this completed question when the GM decides to speak during play.</div>' +
            readyNowBtn +
            backMenuButton(employer.id)
        ));
        return;
    }

    send(box('Sage Research Begun',
        line('Employer', esc(employerName(employer))) +
        line('Sage', esc(sage.name)) +
        line('Question', esc(q.question)) +
        line('Time Frame', esc(questionBroadTimeFrameLabel(q))) +
        '<div style="margin-top:6px;">Research begins. Check Pending Research later. The GM uses <b>Answer Now</b> when the sage is ready to answer during play.</div>' +
        backMenuButton(employer.id)
    ));
}

    function handleAcceptQuestion(msg, args) {
        var employer = resolveEmployer(msg, args);
        var q = getQuestionById(args.question);
        var sage;
        var costGp;
        var body;
        if (!employer || !q || q.employerId !== employer.id) {
            send(box('Sage Question', 'Question quote not found for this employer.' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        if (q.status !== 'quote') {
            send(box('Sage Question', '<div>This question quote is no longer awaiting payment.</div>' + backMenuButton(employer.id)));
            return;
        }
        sage = getSageById(q.sageId);
        if (!sage) {
            send(box('Sage Question', '<div>Sage not found.</div>' + backMenuButton(employer.id)));
            return;
        }
        if (q.employmentType === 'shortterm') {
            ensureShortTermSession(sage, employer);
            if ((sage.shortTerm.daysUsed || 0) + q.billableDays > CONFIG.shortTermMaxDays) {
                send(box('Sage Question',
                    line('Sage', esc(sage.name)) +
                    '<div>This quote would exceed the 7-day short-term limit for this sage.</div>' +
                    line('Days Used', String(sage.shortTerm.daysUsed || 0)) +
                    line('Days Needed', String(q.billableDays)) +
                    backMenuButton(employer.id)
                ));
                return;
            }
        }
        costGp = Math.max(0, parseInt(q.currentCostGp || 0, 10));
        if (costGp > 0 && !deductCoins(employer.id, gpToCp(costGp))) {
            send(box('Sage Question',
                line('Employer', esc(employerName(employer))) +
                line('Cost Due', esc(costGp + ' gp')) +
                '<div>Not enough coin on the employer sheet.</div>' +
                backMenuButton(employer.id)
            ));
            return;
        }
        q.paidCostGp = costGp;
        q.totalCostGp = costGp;
        q.createdDay = state[STATE].currentDay;
        q.readyDay = state[STATE].currentDay + (q.timeUnit === 'days' ? q.timeRoll : 0);
        q.status = q.finalStatus || (q.timeUnit === 'days' ? 'researching' : 'ready');
        q.paidDay = state[STATE].currentDay;
        if (q.employmentType === 'shortterm') {
            sage.shortTerm.daysUsed = Math.max(0, Number(sage.shortTerm.daysUsed) || 0) + q.billableDays;
            if (!_.contains(sage.shortTerm.questionIds, q.id)) sage.shortTerm.questionIds.push(q.id);
        }
        updateCharacterForSage(sage);

        if (q.status === 'ready') {
            body = line('Employer', esc(employerName(employer))) +
                line('Sage', esc(sage.name)) +
                line('Question', esc(q.question)) +
                line('Time Frame', esc(questionBroadTimeFrameLabel(q))) +
                line('Paid', esc(q.paidCostGp + ' gp'));
            body += '<div style="margin-top:6px;">The sage is ready to give the answer to this completed question. The GM uses <b>Answer Now</b> when ready to speak.</div>';
            if (playerIsGM(msg.playerid) && employerCanCollectReadyAnswer(employer, sage, q)) {
                body += '<div style="margin-top:8px;">' + menuBtn('Answer Now', '!sage-set-answer --pc|' + employer.id + ' --question|' + q.id + ' --text|?{GM answer text|}', CONFIG.colors.gmBg, CONFIG.colors.gmBorder, 95) + '</div>';
            }
            body += backMenuButton(employer.id);
            send(box('Sage Question Ready', body));
            return;
        }

        body = line('Employer', esc(employerName(employer))) +
