    function reportActionButtonsForSage(sage, employer) {
    if (!employer) return '';
    var buttons = [];
    if (sage.employment === 'permanent' && sage.ownerId === employer.id) {
        if (!sage.activeStudy) buttons.push(menuBtn('Use Sage', askCommandForSage(employer.id, sage.id), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 85));
        buttons.push(menuBtn('Study', '!sage-study-menu --pc|' + employer.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 75));
    } else if (sage.shortTerm && sage.shortTerm.employerId === employer.id) {
        if (!sage.activeStudy && employerCanConsultSageNow(employer, sage)) buttons.push(menuBtn('Use Sage', askCommandForSage(employer.id, sage.id), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 85));
        buttons.push(menuBtn('End Short-Term', '!sage-end-shortterm --pc|' + employer.id + ' --sage|' + sage.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110));
    } else if (!sage.activeStudy && sage.cooldownUntilDay <= state[STATE].currentDay && sage.employment !== 'permanent' && !sage.shortTerm) {
        buttons.push(menuBtn('Hire Short-Term', '!sage-begin-shortterm --pc|' + employer.id + ' --sage|' + sage.id + ' --days|?{How many days?|1|2|3|4|5|6|7}', CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 115));
        buttons.push(menuBtn('Hire Long-Term', '!sage-offer-employment --pc|' + employer.id + ' --sage|' + sage.id +
            ' --salarygp|?{Salary per month in gp|700}' +
            ' --grantgp|?{Research grant per month in gp|700}' +
            ' --materialsgp|?{Initial material expenditure in gp|20000}', CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110));
    }
    return buttons.join(' ');
}

    function fieldRelationLabel(key) {
        return {
            in: 'In Field',
            out: 'Out of Fields',
            minor: 'Minor Field',
            major: 'Major Field',
            special: 'Special Category'
        }[key] || key;
    }

    function natureLabel(key) {
        return {
            general: 'General',
            specific: 'Specific',
            exacting: 'Exacting'
        }[key] || key;
    }

    function employmentLabel(sage) {
        if (sage.employment === 'permanent') return 'Permanent';
        if (sage.shortTerm) {
            return 'Employed by ' + sage.shortTerm.employerName + ' (' + shortTermDaysRemainingDisplay(sage) + ' day(s) left)';
        }
        if (sageIsResting(sage)) return 'Resting (' + sageRestDaysRemaining(sage) + ' day(s))';
        if (sage.cooldownUntilDay > state[STATE].currentDay) return 'Resting (' + sageRestDaysRemaining(sage) + ' day(s))';
        return 'Available';
    }

    function sageLabel(sage) {
        return sage.name + ' (' + labelForField(sage.majorField) + ')';
    }

    function questionTimeLabel(q) {
        var roll;
        var unit;
        if (!q) return '';
        roll = Math.max(0, Number(q.timeRoll) || 0);
        unit = String(q.timeUnit || 'days');
        if (roll === 1) {
            if (unit === 'days') unit = 'day';
            else if (unit === 'hours') unit = 'hour';
            else if (unit === 'rounds') unit = 'round';
        }
        return roll + ' ' + unit;
    }

    function questionExactTimeLabel(q) {
        return questionTimeLabel(q);
    }

    function questionApproximateDays(q) {
        if (!q) return 0;
        if (q.timeUnit === 'rounds') return 1;
        if (q.timeUnit === 'hours') return 1;
        return Math.max(1, Number(q.timeRoll) || 0);
    }

    function questionBroadTimeFrameLabel(q) {
        return questionTimeLabel(q);
    }

    function questionResearchStatusLabel(q) {
        if (!q) return '';
        if (q.status === 'researching') return 'Research in progress';
        if (q.status === 'ready') return q.sourceKind === 'library' ? 'Research complete' : 'Ready for follow-up';
        if (q.status === 'answered') return 'Answered';
        if (q.status === 'quote') return 'Awaiting payment';
        return q.status;
    }

    function questionSourceLabel(q) {
        return q && q.sourceKind === 'library' ? 'PC Research' : 'Sage Research';
    }

    function sageIsResting(sage) {
        return !!(sage && Number(sage.restUntilDay) > state[STATE].currentDay);
    }

    function restDaysForQuestion(q) {
        if (!q || q.sourceKind !== 'sage') return 0;
        if (q.timeUnit !== 'days') return 0;
        if ((Number(q.timeRoll) || 0) <= 1) return 0;
        return Math.max(1, Math.ceil((Number(q.timeRoll) || 0) / 3));
    }

    function sageRestMessage(sage) {
        if (!sageIsResting(sage)) return '';
        return 'This sage is resting for ' + sageRestDaysRemaining(sage) + ' more day(s). Only general questions may be taken during this rest.';
    }

    function activePcResearchForEmployer(employer) {
        if (!employer) return null;
        return _.find(allQuestions(), function (q) {
            return q.sourceKind === 'library' && q.employerId === employer.id && q.status === 'researching';
        }) || null;
    }

    function blockedByPcResearchText(employer) {
        var q = activePcResearchForEmployer(employer);
        if (!q) return '';
        return 'This character is occupied with PC library research on "' + q.question + '" and cannot begin other research through this system until it is complete.';
    }

    function pcResearchResultText(q) {
        if (!q) return '';
        if (q.status !== 'ready') return 'Library research is still underway.';
        if (!q.intSuccess) return 'Research complete. The intelligence check failed, and no useful answer was found.';
        if (!q.known) return 'Research complete. No useful answer was found.';
        return 'Research complete. Useful information was found; consult the GM for the discovered details.';
    }

    function pcResearchIntelligenceTarget(employer, relation) {
        var base = Number(getAttr(employer.id, CONFIG.intelligenceAttr, 0)) || 0;
        if (relation === 'out') base -= 4;
        return Math.max(1, Math.min(20, base));
    }

    function createPcResearchRecord(employer, args) {
        var relation = normalizeRelationKey(args.relation);
        var nature = normalizeNatureKey(args.nature);
        var sizeKey = normalizeText(args.size || 'medium');
        var size = CONFIG.pcResearch.librarySizes[sizeKey];
        var range = CONFIG.pcResearch.knowledgeTable[relation] && CONFIG.pcResearch.knowledgeTable[relation][nature];
        var discovery = CONFIG.pcResearch.discoveryTable[relation] && CONFIG.pcResearch.discoveryTable[relation][nature];
        var baseChance;
        var effectiveChance;
        var knowRoll;
        var intTarget;
        var intRoll;
        var intSuccess;
        var timeRoll;
        if (!size || !range || !discovery) return { error: 'That PC research combination is not valid.' };
        intTarget = pcResearchIntelligenceTarget(employer, relation);
        if (!(Number(getAttr(employer.id, CONFIG.intelligenceAttr, 0)) || 0)) {
            return { error: 'The employer character needs a numeric "' + CONFIG.intelligenceAttr + '" attribute for PC research.' };
        }
        baseChance = randomIntegerInclusive(range[0], range[1]);
        effectiveChance = Math.max(0, Math.min(100, baseChance + (Number(size.chanceMod) || 0)));
        knowRoll = randomIntegerInclusive(1, 100);
        intRoll = randomIntegerInclusive(1, 20);
        intSuccess = intRoll <= intTarget;
        timeRoll = Math.max(1, Math.ceil(randomIntegerInclusive(discovery.min, discovery.max) * (Number(size.timeMultiplier) || 1)));
        return {
            id: makeQuestionId(),
            sourceKind: 'library',
            pcResearch: true,
            employerId: employer.id,
            employerName: employerName(employer),
            researcherName: employerName(employer),
            sageId: '',
            sageName: 'Research Library (PC)',
            relation: relation,
            nature: nature,
            question: args.question || 'Unnamed question',
            answerText: '',
            baseChance: baseChance,
            effectiveChance: effectiveChance,
            knowRoll: knowRoll,
            known: intSuccess && knowRoll <= effectiveChance,
            intRoll: intRoll,
            intTarget: intTarget,
            intSuccess: intSuccess,
            timeRoll: timeRoll,
            timeUnit: discovery.unit,
            billableDays: timeRoll,
            totalCostGp: 0,
            currentCostGp: 0,
            paidCostGp: 0,
            shortTermBaseGp: 0,
            materialsCostGp: 0,
            remote: false,
            noExtraCost: true,
            quotedDay: state[STATE].currentDay,
            createdDay: state[STATE].currentDay,
            readyDay: state[STATE].currentDay + timeRoll,
            employmentType: 'library',
            finalStatus: 'researching',
            status: 'researching',
            librarySize: sizeKey,
            librarySizeLabel: size.label,
            haggleAttempts: 0,
            haggleFailures: 0,
            haggleDone: true,
            refused: false,
            insulted: false
        };
    }

    function normalizeRelationKey(value) {
        value = normalizeText(value);
        return {
            infield: 'in',
            infields: 'in',
            in: 'in',
            outoffields: 'out',
            outoffield: 'out',
            outsidefields: 'out',
            outsidefield: 'out',
            out: 'out',
            minorfield: 'minor',
            minor: 'minor',
            majorfield: 'major',
            major: 'major',
            specialcategory: 'special',
            special: 'special'
        }[value] || value;
    }

    function normalizeNatureKey(value) {
        value = normalizeText(value);
        return {
            general: 'general',
            specific: 'specific',
            exacting: 'exacting'
        }[value] || value;
    }

    function normalizeLocaleKey(value) {
        value = normalizeText(value);
        return {
            near: 'near',
            yes: 'near',
            remote: 'remote',
            no: 'remote'
        }[value] || value;
    }

    function isRemoteResearch(args) {
        return normalizeLocaleKey(args.locale) === 'remote' || normalizeLocaleKey(args.town) === 'remote';
    }

    function computeEffectiveChance(sage, relation, nature, baseChance) {
        var chance = baseChance;
        if (sage.employment === 'permanent') {
            if (nature === 'specific' || nature === 'exacting') {
                chance = Math.floor(chance * (Number(sage.efficiencyPct) || 0) / 100);
            }
            if (relation === 'out') chance += Number(sage.outsideFieldBonusPct) || 0;
            if (relation === 'minor') chance += Number(sage.minorFieldBonusPct) || 0;
        }
        return Math.max(0, Math.min(100, chance));
    }

    function low20Threshold(range) {
        var size = (range[1] - range[0]) + 1;
        var width = Math.max(1, Math.ceil(size * 0.2));
        return range[0] + width - 1;
    }

    function createQuestionRecord(employer, sage, args) {
    var relation = normalizeRelationKey(args.relation);
    var nature = normalizeNatureKey(args.nature);
    var range = CONFIG.knowledgeTable[relation] && CONFIG.knowledgeTable[relation][nature];
    var discovery = CONFIG.discoveryTable[relation] && CONFIG.discoveryTable[relation][nature];
    if (!range || !discovery) return { error: 'That relation/question type combination is not valid for sage rules.' };

    var baseChance = randomIntegerInclusive(range[0], range[1]);
    var effectiveChance = computeEffectiveChance(sage, relation, nature, baseChance);
    var knowRoll = randomIntegerInclusive(1, 100);
    var known = knowRoll <= effectiveChance;
    var remote = isRemoteResearch(args);
    var timeRoll = randomIntegerInclusive(discovery.min, discovery.max);
    var timeUnit = discovery.unit;

    if (remote && timeUnit === 'days') timeRoll *= 2;

    return {
        id: makeQuestionId(),
        sourceKind: 'sage',
        employerId: employer.id,
        employerName: employerName(employer),
        reactionBonus: getReactionBonus(employer.id),
        sageId: sage.id,
        sageName: sage.name,
        relation: relation,
        nature: nature,
        question: args.question || 'Unnamed question',
        answerText: '',
        baseChance: baseChance,
        effectiveChance: effectiveChance,
        knowRoll: knowRoll,
        known: known,
        timeRoll: timeRoll,
        timeUnit: timeUnit,
        billableDays: timeUnit === 'days' ? timeRoll : 0,
        totalCostGp: 0,
        currentCostGp: sage.employment === 'permanent' ? 0 : (discovery.costGpPerDay * (remote ? 2 : 1)),
        paidCostGp: 0,
        shortTermBaseGp: 0,
        materialsCostGp: sage.employment === 'permanent' ? 0 : (discovery.costGpPerDay * (remote ? 2 : 1)),
        remote: remote,
        noExtraCost: sage.employment === 'permanent',
        quotedDay: state[STATE].currentDay,
        createdDay: state[STATE].currentDay,
        readyDay: state[STATE].currentDay + (timeUnit === 'days' ? timeRoll : 0),
        employmentType: sage.employment === 'permanent' ? 'permanent' : 'shortterm',
        finalStatus: timeUnit === 'days' ? 'researching' : 'ready',
        status: sage.employment === 'permanent' ? (timeUnit === 'days' ? 'researching' : 'ready') : 'quote',
        haggleAttempts: 0,
        haggleFailures: 0,
        haggleDone: sage.employment === 'permanent',
        refused: false,
        insulted: false
    };
}

    function canBeginShortTerm(sage, employer) {
    if (sage.employment === 'permanent') return { ok: false, msg: 'This sage is permanently employed.' };
    if (sage.cooldownUntilDay > state[STATE].currentDay) {
        return { ok: false, msg: 'This sage is resting for ' + sageRestDaysRemaining(sage) + ' more day(s).' };
    }
    if (sage.activeStudy) {
        return { ok: false, msg: 'This sage is in uninterrupted study and cannot be questioned.' };
    }
    if (!sage.shortTerm) return { ok: true };
    if (sage.shortTerm.employerId !== employer.id) {
        return { ok: false, msg: 'This sage is already employed by ' + sage.shortTerm.employerName + ' for ' + shortTermDaysRemainingDisplay(sage) + ' more day(s).' };
    }
    return { ok: true };
}

    function ensureShortTermSession(sage, employer, paidDays) {
    var addDays = Math.max(0, Number(paidDays) || 0);
    if (!sage.shortTerm) {
        sage.shortTerm = {
            employerId: employer.id,
            employerName: employerName(employer),
            startDay: state[STATE].currentDay,
            paidThroughDay: state[STATE].currentDay + addDays,
            totalPaidDays: addDays,
            daysUsed: 0,
            extensionCount: 0,
            questionIds: []
        };
        return;
    }
    sage.shortTerm.daysUsed = Math.max(0, Number(sage.shortTerm.daysUsed) || 0);
    sage.shortTerm.totalPaidDays = Math.max(0, Number(sage.shortTerm.totalPaidDays) || 0);
    sage.shortTerm.extensionCount = Math.max(0, Number(sage.shortTerm.extensionCount) || 0);
    if (!_.isArray(sage.shortTerm.questionIds)) sage.shortTerm.questionIds = [];
    if (sage.shortTerm.employerId === employer.id && addDays) {
        sage.shortTerm.paidThroughDay = Math.max(state[STATE].currentDay, Number(sage.shortTerm.paidThroughDay) || 0) + addDays;
        sage.shortTerm.totalPaidDays += addDays;
        sage.shortTerm.extensionCount += 1;
    }
}

    function shortTermResearchingQuestion(sage) {
    return _.find(allQuestions(), function (q) {
        return q.sageId === sage.id && q.employmentType === 'shortterm' && q.status === 'researching';
    });
}

    function shortTermReadyQuestion(sage) {
    return _.find(allQuestions(), function (q) {
        return q.sageId === sage.id && q.employmentType === 'shortterm' && q.status === 'ready';
    });
}

    function employerCanCollectReadyAnswer(employer, sage, question) {
    if (!employer || !sage || !question || question.sourceKind !== 'sage') return false;
    if (question.employerId !== employer.id || question.sageId !== sage.id || question.status !== 'ready') return false;
    if (sage.employment === 'permanent') return sage.ownerId === employer.id;
    return !!(sage.shortTerm && sage.shortTerm.employerId === employer.id && (shortTermActiveToday(sage) || !!shortTermReadyQuestion(sage)));
}

function shortTermDaysRemaining(sage) {
    if (!sage || !sage.shortTerm) return 0;
    return Math.max(0, (Number(sage.shortTerm.paidThroughDay) || 0) - state[STATE].currentDay);
}

function shortTermActiveToday(sage) {
    if (!sage || !sage.shortTerm) return false;
    return state[STATE].currentDay <= (Number(sage.shortTerm.paidThroughDay) || 0);
}

function remainingDaysUntil(targetDay) {
    return Math.max(0, (Number(targetDay) || 0) - state[STATE].currentDay);
}

function remainingInclusiveDaysUntil(targetDay) {
    return Math.max(0, ((Number(targetDay) || 0) - state[STATE].currentDay) + 1);
}

function shortTermDaysRemainingDisplay(sage) {
    if (!sage || !sage.shortTerm) return 0;
    return remainingInclusiveDaysUntil(sage.shortTerm.paidThroughDay);
}

function sageLockedByOtherEmployer(sage, employer) {
    return !!(sage && sage.shortTerm && employer && sage.shortTerm.employerId !== employer.id && shortTermActiveToday(sage));
}

function sageRestDaysRemaining(sage) {
    if (!sage) return 0;
    if (sageIsResting(sage)) return remainingDaysUntil(sage.restUntilDay);
    if ((Number(sage.cooldownUntilDay) || 0) > state[STATE].currentDay) return remainingDaysUntil(sage.cooldownUntilDay);
    return 0;
}

function employerCanConsultSageNow(employer, sage) {
    if (!employer || !sage) return false;
    if (sage.employment === 'permanent') return sage.ownerId === employer.id;
    return !!(sage.shortTerm && sage.shortTerm.employerId === employer.id && shortTermActiveToday(sage));
}

function finishShortTermIfIdle(sage) {
    if (!sage || !sage.shortTerm) return;
    if (shortTermResearchingQuestion(sage) || shortTermReadyQuestion(sage)) return;
    if (state[STATE].currentDay <= (Number(sage.shortTerm.paidThroughDay) || 0)) return;
    sage.cooldownUntilDay = state[STATE].currentDay + CONFIG.cooldownDaysAfterShortTerm;
    sage.shortTerm = null;
}

