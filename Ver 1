    function handleOfferEmployment(msg, args) {
    var employer = resolveEmployer(msg, args);
    var sage = getSageById(args.sage);
    var salaryGp;
    var grantGp;
    var materialsGp;
    var reactionBonus;
    var reactionRoll;
    var favorable;
    var salaryExpectation;
    var grantExpectation;
    var meetsMoney;
    var quote;
    if (!employer || !sage) {
        send(box('Hire Long-Term Sage', 'Employer or sage not found.' + backMenuButton(employer ? employer.id : '')));
        return;
    }
    if (activePcResearchForEmployer(employer)) {
        send(box('Hire Long-Term Sage', '<div>' + esc(blockedByPcResearchText(employer)) + '</div>' + backMenuButton(employer.id)));
        return;
    }
    if (sage.employment === 'permanent') {
        send(box('Hire Long-Term Sage', '<div>This sage is already permanently employed.</div>' + backMenuButton(employer.id)));
        return;
    }
    salaryGp = Math.max(0, parseInt(args.salarygp || 0, 10));
    grantGp = Math.max(0, parseInt(args.grantgp || 0, 10));
    materialsGp = Math.max(0, parseInt(args.materialsgp || 0, 10));
    if (materialsGp < 20000) {
        send(box('Hire Long-Term Sage', '<div>Initial material expenditure must be at least 20,000 gp.</div>' + backMenuButton(employer.id)));
        return;
    }
    reactionBonus = getReactionBonus(employer.id);
    reactionRoll = hireEligibilityRoll(reactionBonus);
    favorable = reactionRoll >= 11;
    salaryExpectation = salaryExpectationFrom2d6();
    grantExpectation = salaryExpectationFrom2d6();
    meetsMoney = salaryGp >= salaryExpectation && grantGp >= grantExpectation;

    if (!favorable || !meetsMoney) {
        send(box('Hire Long-Term Sage',
            line('Sage', esc(sage.name)) +
            line('Offer', esc(salaryGp + ' gp salary, ' + grantGp + ' gp grant, ' + materialsGp + ' gp materials')) +
            '<div>The sage declines permanent employment.</div>' +
            backMenuButton(employer.id)
        ));
        return;
    }

    quote = buildHireQuote(employer, sage, 'longterm', {
        currentCostGp: salaryGp + grantGp + materialsGp,
        salaryGp: salaryGp,
        grantGp: grantGp,
        materialsGp: materialsGp,
        reactionRoll: reactionRoll,
        favorable: favorable,
        salaryExpectationGp: salaryExpectation,
        grantExpectationGp: grantExpectation
    });
    allHireQuotes().push(quote);
    renderHireQuote(quote, employer, 'Payment is made up front. Once paid, this sage may begin answering questions under the long-term employment rules.');
}

function handleAcceptHireQuote(msg, args) {
    var employer = resolveEmployer(msg, args);
    var quote = getHireQuoteById(args.quote);
    var sage;
    var costCp;
    var linkedQuestion;
    if (!employer || !quote || quote.employerId !== employer.id || quote.status !== 'quote') {
        send(box('Sage Quote', '<div>Quote not found for this employer.</div>' + backMenuButton(employer ? employer.id : '')));
        return;
    }
    sage = getSageById(quote.sageId);
    if (!sage) {
        removeHireQuote(quote.id);
        send(box('Sage Quote', '<div>Sage not found.</div>' + backMenuButton(employer.id)));
        return;
    }
    costCp = gpToCp(quote.currentCostGp);
    if (costCp > 0 && !deductCoins(employer.id, costCp)) {
        send(box(hireQuoteTitle(quote),
            line('Employer', esc(employerName(employer))) +
            line('Amount Due', esc(formatCoinsFromCp(costCp))) +
            '<div>Not enough coin on the employer sheet.</div>' +
            backMenuButton(employer.id)
        ));
        return;
    }

    if (quote.kind === 'shortterm') {
        ensureShortTermSession(sage, employer, quote.days);
        removeHireQuote(quote.id);
        updateCharacterForSage(sage);
        send(box('Short-Term Sage Hired',
            line('Employer', esc(employerName(employer))) +
            line('Sage', esc(sage.name)) +
            line('Days Paid', String(quote.days)) +
            line('Paid', esc(quote.currentCostGp + ' gp')) +
            menuBtn('Ask Question', askCommandForSage(employer.id, sage.id), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 110) +
            backMenuButton(employer.id)
        ));
        return;
    }

    if (quote.kind === 'extension') {
        linkedQuestion = getQuestionById(quote.linkedQuestionId);
        ensureShortTermSession(sage, employer, quote.days);
        removeHireQuote(quote.id);
        if (linkedQuestion) {
            linkedQuestion.status = linkedQuestion.finalStatus || 'researching';
            linkedQuestion.createdDay = state[STATE].currentDay;
        }
        updateCharacterForSage(sage);
        send(box('Short-Term Extended',
            line('Employer', esc(employerName(employer))) +
            line('Sage', esc(sage.name)) +
            line('Additional Days Paid', String(quote.days)) +
            line('Paid', esc(quote.currentCostGp + ' gp')) +
            (linkedQuestion ? line('Time Frame', esc(questionBroadTimeFrameLabel(linkedQuestion))) : '') +
            '<div>The rest period begins only after any research from this extension is completed.</div>' +
            backMenuButton(employer.id)
        ));
        return;
    }

    if (quote.kind === 'longterm') {
        sage.employment = 'permanent';
        sage.ownerId = employer.id;
        sage.ownerName = employerName(employer);
        sage.salaryGp = quote.salaryGp;
        sage.grantGp = quote.grantGp;
        sage.materialsGp = quote.materialsGp;
        sage.efficiencyPct = efficiencyFromMaterials(quote.materialsGp);
        sage.monthlyDueDay = state[STATE].currentDay + CONFIG.daysPerMonth;
        sage.hireRoll = quote.reactionRoll;
        sage.salaryExpectationGp = quote.salaryExpectationGp;
        sage.grantExpectationGp = quote.grantExpectationGp;
        sage.shortTerm = null;
        removeHireQuote(quote.id);
        updateCharacterForSage(sage);
        send(box('Long-Term Sage Hired',
            line('Employer', esc(employerName(employer))) +
            line('Sage', esc(sage.name)) +
            line('Paid Now', esc(quote.currentCostGp + ' gp')) +
            line('Salary', esc(quote.salaryGp + ' gp/month')) +
            line('Grant', esc(quote.grantGp + ' gp/month')) +
            line('Materials', esc(quote.materialsGp + ' gp')) +
            line('Efficiency', String(sage.efficiencyPct) + '%') +
            menuBtn('Ask Question', askCommandForSage(employer.id, sage.id), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 110) +
            backMenuButton(employer.id)
        ));
    }
}

