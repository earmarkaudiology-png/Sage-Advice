    function stateInit() {
        if (!state[STATE]) {
            state[STATE] = {
                version: VERSION,
                currentDay: 0,
                nextSageId: 1,
                nextQuestionId: 1,
                nextHireQuoteId: 1,
                sages: [],
                questions: [],
                hireQuotes: []
            };
        }
        state[STATE].version = VERSION;
        state[STATE].currentDay = Number(state[STATE].currentDay) || 0;
        state[STATE].nextSageId = Number(state[STATE].nextSageId) || 1;
        state[STATE].nextQuestionId = Number(state[STATE].nextQuestionId) || 1;
        state[STATE].nextHireQuoteId = Number(state[STATE].nextHireQuoteId) || 1;
        state[STATE].sages = state[STATE].sages || [];
        state[STATE].questions = state[STATE].questions || [];
        state[STATE].hireQuotes = state[STATE].hireQuotes || [];
        _.each(state[STATE].sages, function (sage) {
            sage.cooldownUntilDay = Number(sage.cooldownUntilDay) || 0;
            sage.restUntilDay = Number(sage.restUntilDay) || 0;
            sage.restDaysRequired = Number(sage.restDaysRequired) || 0;
            sage.restWarning = sage.restWarning || '';
            if (sage.shortTerm) {
                sage.shortTerm.paidThroughDay = Number(sage.shortTerm.paidThroughDay) || 0;
                sage.shortTerm.totalPaidDays = Number(sage.shortTerm.totalPaidDays) || 0;
                sage.shortTerm.daysUsed = Number(sage.shortTerm.daysUsed) || 0;
                sage.shortTerm.extensionCount = Number(sage.shortTerm.extensionCount) || 0;
                if (!_.isArray(sage.shortTerm.questionIds)) sage.shortTerm.questionIds = [];
            }
        });
        _.each(state[STATE].questions, function (q) {
            q.sourceKind = q.sourceKind || 'sage';
            q.readyDay = Number(q.readyDay) || 0;
            q.createdDay = Number(q.createdDay) || 0;
            q.timeRoll = Number(q.timeRoll) || 0;
            q.pcResearch = !!q.pcResearch || q.sourceKind === 'library';
        });
    }

    function esc(s) {
        return String(s === undefined || s === null ? '' : s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function normalizeText(s) {
        return String(s || '').toLowerCase().replace(/\s+/g, ' ').trim();
    }

    function slugify(s) {
        return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, '');
    }

    function parseArgs(content) {
        var args = {};
        var i = 0;
        var len = (content || '').length;
        var keyStart, keyEnd, key, valStart, depth, ch;
        content = String(content || '');

        while (i < len) {
            i = content.indexOf('--', i);
            if (i === -1) break;
            i += 2;
            keyStart = i;
            while (i < len && !/\s|\|/.test(content.charAt(i))) i += 1;
            keyEnd = i;
            key = content.substring(keyStart, keyEnd);
            if (!key) continue;
            if (content.charAt(i) !== '|') {
                args[key] = 'yes';
                continue;
            }
            i += 1;
            valStart = i;
            depth = 0;
            while (i < len) {
                ch = content.charAt(i);
                if (ch === '{') depth += 1;
                else if (ch === '}' && depth > 0) depth -= 1;
                if (depth === 0 && ch === ' ' && content.substr(i + 1, 2) === '--') break;
                i += 1;
            }
            args[key] = content.substring(valStart, i).trim();
        }
        return args;
    }

