        }
        send(box('Sage Study and Library Upgrades',
            '<div style="margin-bottom:6px;">No questions may be asked during the study period or the investment is wasted. This script blocks questions while study is active.</div>' +
            sageButtons(function (s) { return s.employment === 'permanent' && s.ownerId === employer.id && !s.activeStudy; }, function (s) {
                return menuBtn('Outside +1%', '!sage-start-study --pc|' + employer.id + ' --sage|' + s.id + ' --kind|outsidebonus', CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 95) +
                    menuBtn('Minor +1%', '!sage-start-study --pc|' + employer.id + ' --sage|' + s.id + ' --kind|minorbonus', CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 95) +
                    menuBtn('Add Minor', '!sage-start-study --pc|' + employer.id + ' --sage|' + s.id + ' --kind|addminor --field|?{New minor field|' + requirementListForMenu() + '}', CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 90) +
                    menuBtn('Add Major', '!sage-start-study --pc|' + employer.id + ' --sage|' + s.id + ' --kind|addmajor --field|?{New major field|' + requirementListForMenu() + '}', CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 90);
            }, 'No permanently employed sages available for study.') +
            backMenuButton(employer.id)
        ));
    }

    function handleStartStudy(msg, args) {
        var employer = resolveEmployer(msg, args);
        var sage = getSageById(args.sage);
        if (!employer || !sage || sage.employment !== 'permanent' || sage.ownerId !== employer.id) {
            send(box('Sage Study', 'Employer or sage not found.' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        if (sage.activeStudy) {
            send(box('Sage Study', '<div>This sage is already studying.</div>' + backMenuButton(employer.id)));
            return;
        }
        var kind = normalizeText(args.kind);
        var gpCost = 0;
        var days = 0;
        var label = '';
        var fieldKey = null;
        if (kind === 'outsidebonus') {
            if ((sage.outsideFieldBonusPct || 0) >= 5) {
                send(box('Sage Study', '<div>Outside-field bonus is already at the 5% maximum.</div>' + backMenuButton(employer.id)));
                return;
            }
            gpCost = 5000;
            days = CONFIG.daysPerMonth;
            label = 'Outside-field knowledge +1%';
        } else if (kind === 'minorbonus') {
            if ((sage.minorFieldBonusPct || 0) >= 5) {
                send(box('Sage Study', '<div>Minor-field bonus is already at the 5% maximum.</div>' + backMenuButton(employer.id)));
                return;
            }
            gpCost = 10000;
            days = CONFIG.daysPerMonth;
            label = 'Minor-field knowledge +1%';
        } else if (kind === 'addminor') {
            fieldKey = resolveFieldKey(args.field);
            if (!fieldKey || fieldKey === sage.majorField || _.contains(sage.minorFields, fieldKey)) {
                send(box('Sage Study', '<div>Choose a valid new minor field.</div>' + backMenuButton(employer.id)));
                return;
            }
            if (sage.minorFields.length >= 3) {
                send(box('Sage Study', '<div>This sage already has the maximum three minor fields.</div>' + backMenuButton(employer.id)));
                return;
            }
            gpCost = 100000;
            days = 2 * 365;
            label = 'Add minor field: ' + labelForField(fieldKey);
        } else if (kind === 'addmajor') {
            fieldKey = resolveFieldKey(args.field);
            if (!fieldKey || fieldKey === sage.majorField || _.contains(sage.minorFields, fieldKey)) {
                send(box('Sage Study', '<div>Choose a valid new major field.</div>' + backMenuButton(employer.id)));
                return;
            }
            gpCost = 200000;
            days = 2 * 365;
            label = 'Add major field: ' + labelForField(fieldKey);
        } else {
            send(box('Sage Study', '<div>Unknown study type.</div>' + backMenuButton(employer.id)));
            return;
        }
        if (!deductCoins(employer.id, gpToCp(gpCost))) {
            send(box('Sage Study',
                line('Employer', esc(employerName(employer))) +
                line('Amount Due Now', esc(gpCost + ' gp')) +
                '<div>Not enough coin on the employer sheet.</div>' +
                backMenuButton(employer.id)
            ));
            return;
        }
        sage.activeStudy = {
            kind: kind,
            label: label,
            startDay: state[STATE].currentDay,
            endDay: state[STATE].currentDay + days,
            fieldKey: fieldKey
        };
        send(box('Sage Study Begun',
            line('Sage', esc(sage.name)) +
            line('Study', esc(label)) +
            line('Cost Paid', esc(gpCost + ' gp')) +
            line('Ends on Day', String(sage.activeStudy.endDay)) +
            backMenuButton(employer.id)
        ));
    }

    function handlePcResearchMenu(msg, args) {
        var employer = resolveEmployer(msg, args);
        if (!employer) {
            send(box('PC Research', 'Select an employer token first.' + backMenuButton('')));
            return;
        }
        if (activePcResearchForEmployer(employer)) {
            send(box('PC Research', '<div>' + esc(blockedByPcResearchText(employer)) + '</div>' + backMenuButton(employer.id)));
            return;
        }
        send(box('PC Research',
            '<div style="margin-bottom:6px;">This uses the employer\'s research library and intelligence. While this research is in progress, the character is treated as occupied and cannot begin other research through this script.</div>' +
            menuBtn('Begin PC Research', pcResearchCommand(employer.id), CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 135) +
            backMenuButton(employer.id)
        ));
    }

    function handlePcResearchStart(msg, args) {
        var employer = resolveEmployer(msg, args);
        var q;
        if (!employer) {
            send(box('PC Research', 'Select an employer token first.' + backMenuButton('')));
            return;
        }
        if (activePcResearchForEmployer(employer)) {
            send(box('PC Research', '<div>' + esc(blockedByPcResearchText(employer)) + '</div>' + backMenuButton(employer.id)));
            return;
        }
        q = createPcResearchRecord(employer, args);
        if (q.error) {
            send(box('PC Research', '<div>' + esc(q.error) + '</div>' + backMenuButton(employer.id)));
            return;
        }
        allQuestions().push(q);
        send(box('PC Research Begun',
            line('Researcher', esc(employerName(employer))) +
            line('Question', esc(q.question)) +
            line('Library', esc(q.librarySizeLabel)) +
            line('Field Relation', esc(fieldRelationLabel(q.relation))) +
            line('Question Type', esc(natureLabel(q.nature))) +
            line('Time Frame', esc(questionBroadTimeFrameLabel(q))) +
            '<div style="margin-top:6px;">Research begins. Check Pending Research after the GM applies days.</div>' +
            backMenuButton(employer.id)
        ));
    }

    function handleSetAnswer(msg, args) {
        var employer = resolveEmployer(msg, args);
        var q = getQuestionById(args.question);
        var sage;
        var answerText;
        if (!playerIsGM(msg.playerid)) return;
        if (!q) {
            send(box('Set Sage Answer', '<div>Question not found.</div>' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        if (q.sourceKind !== 'sage') {
            send(box('Set Sage Answer', '<div>Answer Now only applies to sage research.</div>' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        sage = getSageById(q.sageId);
        if (!sage) {
            send(box('Set Sage Answer', '<div>Sage not found.</div>' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        if (!employerCanCollectReadyAnswer(employer, sage, q)) {
            send(box('Set Sage Answer', '<div>The employer for this question is the only character who may collect this completed answer.</div>' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        answerText = String(args.text || '').trim();
        if (!answerText) {
            answerText = q.known ? 'The sage gives the prepared answer.' : 'After consideration, the sage has no answer to offer.';
        }
        q.answerText = answerText;
        q.status = 'answered';
        q.answeredDay = state[STATE].currentDay;
        var restDays = restDaysForQuestion(q);
        var restNote = '';
        if (restDays > 0) {
            sage.restDaysRequired = restDays;
            sage.restUntilDay = state[STATE].currentDay + restDays;
            sage.restWarning = 'After answering this question, the sage requires ' + restDays + ' day(s) of rest. During this time, only general questions should be asked.';
            restNote = '<div style="margin-top:6px;"><b>Rest Required:</b> ' + esc(sage.restWarning) + '</div>';
        } else {
            sage.restDaysRequired = 0;
            sage.restWarning = '';
        }
        send(box('Sage Answer',
            line('Employer', esc(q.employerName)) +
            line('Sage', esc(q.sageName)) +
            line('Question', esc(q.question)) +
            '<div style="margin-top:6px;"><b>Answer:</b> ' + esc(q.answerText) + '</div>' +
            restNote +
            backMenuButton(employer ? employer.id : '')
        ));
        if (sage.temporary) {
            state[STATE].sages = _.reject(allSages(), function (s) { return s.id === sage.id; });
        }
        finishShortTermIfIdle(sage);
    }

    function handleReset(msg, args) {
        if (!playerIsGM(msg.playerid)) return;
        if (normalizeText(args.confirm) !== 'yes') {
            send(box('Reset Sage Data', '<div>Reset cancelled.</div>' + backMenuButton('')));
            return;
        }
        state[STATE] = {
            version: VERSION,
            currentDay: 0,
            nextSageId: 1,
            nextQuestionId: 1,
            nextHireQuoteId: 1,
            sages: [],
            questions: [],
            hireQuotes: []
        };
        send(box('Reset Sage Data', '<div>All sage data removed.</div>' + backMenuButton('')));
    }

    function handleInput(msg) {
    if (msg.type !== 'api') return;
    var cmd = (msg.content || '').split(/\s+/)[0];
    var args = parseArgs(msg.content || '');
    if (cmd === '!sage-menu') return buildMainMenu(msg, args);
    if (cmd === '!sage-add-menu') return handleAddMenu(msg, args);
    if (cmd === '!sage-add-random') return handleAddRandom(msg, args);
    if (cmd === '!sage-add-custom-menu') return handleAddCustomMenu(msg, args);
    if (cmd === '!sage-add-custom-fields') return handleAddCustomFields(msg, args);
    if (cmd === '!sage-add-custom') return handleAddCustom(msg, args);
    if (cmd === '!sage-report') return handleReport(msg, args);
    if (cmd === '!sage-report-public') return handleReportPublic(msg, args);
    if (cmd === '!sage-remove-list') return handleRemoveList(msg, args);
    if (cmd === '!sage-remove') return handleRemove(msg, args);
    if (cmd === '!sage-begin-shortterm-menu') return handleBeginShortTermMenu(msg, args);
    if (cmd === '!sage-begin-shortterm') return handleBeginShortTerm(msg, args);
    if (cmd === '!sage-ask-menu') return handleAskMenu(msg, args);
    if (cmd === '!sage-ask') return handleAsk(msg, args);
    if (cmd === '!sage-accept-question') return handleAcceptQuestion(msg, args);
    if (cmd === '!sage-deny-question') return handleDenyQuestion(msg, args);
    if (cmd === '!sage-haggle-question') return handleHaggleQuestion(msg, args);
    if (cmd === '!sage-open-questions') return handleOpenQuestions(msg, args);
    if (cmd === '!sage-how-sages-work') return handleHowSagesWork(msg, args);
    if (cmd === '!sage-pc-research-menu') return handlePcResearchMenu(msg, args);
    if (cmd === '!sage-pc-research-start') return handlePcResearchStart(msg, args);
    if (cmd === '!sage-pc-research-rules') return handlePcResearchRules(msg, args);
    if (cmd === '!sage-chance-chart') return handleChanceChart(msg, args);
    if (cmd === '!sage-time-chart') return handleTimeChart(msg, args);
    if (cmd === '!sage-apply-days') return handleApplyDays(msg, args);
    if (cmd === '!sage-apply-months') return handleApplyMonths(msg, args);
    if (cmd === '!sage-end-shortterm-menu') return handleEndShortTermMenu(msg, args);
    if (cmd === '!sage-end-shortterm') return handleEndShortTerm(msg, args);
    if (cmd === '!sage-hire-menu') return handleHireMenu(msg, args);
    if (cmd === '!sage-offer-employment') return handleOfferEmployment(msg, args);
    if (cmd === '!sage-accept-hirequote') return handleAcceptHireQuote(msg, args);
    if (cmd === '!sage-deny-hirequote') return handleDenyHireQuote(msg, args);
    if (cmd === '!sage-haggle-hirequote') return handleHaggleHireQuote(msg, args);
    if (cmd === '!sage-study-menu') return handleStudyMenu(msg, args);
    if (cmd === '!sage-start-study') return handleStartStudy(msg, args);
    if (cmd === '!sage-set-answer') return handleSetAnswer(msg, args);
    if (cmd === '!sage-reset') return handleReset(msg, args);
}

    function registerEventHandlers() {
        on('chat:message', handleInput);
    }

    on('ready', function () {
        stateInit();
        registerEventHandlers();
        log(SCRIPT + ' v' + VERSION + ' ready.');
    });

    return {
        _stateInit: stateInit
    };
}());
