    function allSages() {
        return state[STATE].sages;
    }

    function randomName() {
        return randomPick(CONFIG.randomNames) + ' the Sage';
    }

    function randomAlignment() {
        var roll = randomIntegerInclusive(1, 100);
        var found = _.find(CONFIG.alignmentTable, function (row) { return roll <= row[0]; });
        return found ? found[1] : 'Neutral';
    }

    function fieldKeys() {
        return CONFIG.fieldOrder.slice();
    }

    function labelForField(key) {
        return CONFIG.fields[key] ? CONFIG.fields[key].label : key;
    }

    function resolveFieldKey(raw) {
        var txt = slugify(raw);
        var found = _.find(fieldKeys(), function (k) {
            return slugify(k) === txt || slugify(CONFIG.fields[k].label) === txt;
        });
        return found || null;
    }

    function resolveSpecialForField(fieldKey, raw) {
        var field = CONFIG.fields[fieldKey];
        if (!field) return null;
        var txt = slugify(raw);
        return _.find(field.specials, function (s) { return slugify(s) === txt; }) || null;
    }

    function rollMinorAndSpecialCounts() {
        var roll = randomIntegerInclusive(1, 100);
        if (roll <= 10) return { minorCount: 1, specialCount: 2 };
        if (roll <= 30) return { minorCount: 1, specialCount: 3 };
        if (roll <= 50) return { minorCount: 1, specialCount: 4 };
        if (roll <= 70) return { minorCount: 2, specialCount: 2 };
        if (roll <= 90) return { minorCount: 2, specialCount: 3 };
        return { minorCount: 2, specialCount: 4 };
    }

    function rollStats() {
        return {
            strength: randomIntegerInclusive(1, 8) + 7,
            intelligence: randomIntegerInclusive(1, 4) + 14,
            wisdom: randomIntegerInclusive(1, 6) + 12,
            dexterity: randomIntegerInclusive(1, 6) + randomIntegerInclusive(1, 6) + randomIntegerInclusive(1, 6),
            constitution: randomIntegerInclusive(1, 6) + randomIntegerInclusive(1, 6) + 3,
            charisma: randomIntegerInclusive(1, 6) + randomIntegerInclusive(1, 6) + 2
        };
    }

    function constitutionBonus(score) {
        score = Number(score) || 0;
        if (score >= 15) return 1;
        if (score <= 6) return -1;
        return 0;
    }

    function rollHitPoints(conScore) {
        var hp = 0;
        var bonus = constitutionBonus(conScore);
        var i;
        for (i = 0; i < 8; i += 1) hp += randomIntegerInclusive(1, 4) + bonus;
        return Math.max(1, hp);
    }


    function chooseDistinct(arr, count) {
        var pool = (arr || []).slice();
        var limit = Math.min(pool.length, Math.max(0, parseInt(count || 0, 10) || 0));
        var i, j, tmp;
        for (i = pool.length - 1; i > 0; i -= 1) {
            j = randomIntegerInclusive(0, i);
            tmp = pool[i];
            pool[i] = pool[j];
            pool[j] = tmp;
        }
        return pool.slice(0, limit);
    }


    function mapSageAgeToNpcAppearanceAge(ageCategory) {
        var n = normalizeText(ageCategory || '');
        if (n === 'old') return 'old';
        if (n === 'venerable') return 'ancient';
        return 'middle-aged';
    }

    function rollNpcTableResult(values) {
        return randomPick(values || []);
    }

    function rollNpcSanity() {
        var result = rollNpcTableResult(NPC_TABLES.sanity);
        if (result === 'insane' || result === 'maniacal') {
            result = rollNpcTableResult(NPC_TABLES.sanity);
        }
        return result;
    }

    function rollNpcMorals() {
        var result = rollNpcTableResult(NPC_TABLES.morals);
        if (result === 'perverted' || result === 'sadistic' || result === 'depraved') {
            result = rollNpcTableResult(NPC_TABLES.morals);
        }
        return result;
    }

    function rollNpcPersonality() {
        var styleRoll = randomIntegerInclusive(1, 8);
        if (styleRoll <= 5) {
            return { type: 'Average', trait: rollNpcTableResult(NPC_TABLES.personalityAverage) };
        }
        if (styleRoll <= 7) {
            return { type: 'Extroverted', trait: rollNpcTableResult(NPC_TABLES.personalityExtroverted) };
        }
        return { type: 'Introverted', trait: rollNpcTableResult(NPC_TABLES.personalityIntroverted) };
    }

    function generateNpcProfileForSage(ageCategory) {
        var personality = rollNpcPersonality();
        var interest = rollNpcTableResult(NPC_TABLES.interests);
        var collection = interest === 'collector' ? rollNpcTableResult(NPC_TABLES.collections) : '';
        var profile = {
            appearanceAge: mapSageAgeToNpcAppearanceAge(ageCategory),
            appearanceGeneral: rollNpcTableResult(NPC_TABLES.appearanceGeneral),
            sanity: rollNpcSanity(),
            generalTendency: rollNpcTableResult(NPC_TABLES.generalTendencies),
            personalityType: personality.type,
            personalityTrait: personality.trait,
            disposition: rollNpcTableResult(NPC_TABLES.disposition),
            intellect: rollNpcTableResult(NPC_TABLES.intellect),
            nature: rollNpcTableResult(NPC_TABLES.nature),
            materialism: rollNpcTableResult(NPC_TABLES.materialism),
            honesty: rollNpcTableResult(NPC_TABLES.honesty),
            bravery: rollNpcTableResult(NPC_TABLES.bravery),
            energy: rollNpcTableResult(NPC_TABLES.energy),
            thrift: rollNpcTableResult(NPC_TABLES.thrift),
            morals: rollNpcMorals(),
            piety: rollNpcTableResult(NPC_TABLES.piety),
            interest: interest,
            collection: collection
        };
        profile.summary = [
            'Appearance: ' + profile.appearanceGeneral,
            'Tendency: ' + profile.generalTendency,
            'Trait: ' + profile.personalityTrait
        ].join(' | ');
        return profile;
    }

    function buildRandomSage(overrides) {
        overrides = overrides || {};
        var counts = rollMinorAndSpecialCounts();
        var major = resolveFieldKey(overrides.major) || randomPick(fieldKeys());
        var remaining = _.reject(fieldKeys(), function (k) { return k === major; });
        var minorList = parseList(overrides.minors || overrides.minor || '');
        var minors = _.chain(minorList)
            .map(resolveFieldKey)
            .filter(function (k) { return !!k && k !== major; })
            .uniq()
            .value();
        if (minors.length < counts.minorCount) {
            minors = minors.concat(chooseDistinct(_.reject(remaining, function (k) { return _.contains(minors, k); }), counts.minorCount - minors.length));
        }
        minors = minors.slice(0, counts.minorCount);
        var specialInput = parseList(overrides.specials || overrides.special || '');
        var specials = _.chain(specialInput)
            .map(function (s) { return resolveSpecialForField(major, s); })
            .filter(function (s) { return !!s; })
            .uniq()
            .value();
        if (specials.length < counts.specialCount) {
            specials = specials.concat(chooseDistinct(_.reject(CONFIG.fields[major].specials, function (s) { return _.contains(specials, s); }), counts.specialCount - specials.length));
        }
        specials = specials.slice(0, counts.specialCount);
        return finalizeSageData({
            name: overrides.name || randomName(),
            majorField: major,
            minorFields: minors,
            specialCategories: specials,
            temporary: normalizeText(overrides.temporary) === 'yes',
            alignment: overrides.alignment || randomAlignment(),
            ageCategory: overrides.agecategory || randomAgeCategory(),
            spellTypeOverride: overrides.spelltype || ''
        });
    }

    function parseList(raw) {
        return _.chain(String(raw || '').split(/[,;]/))
            .map(function (s) { return normalizeText(s); })
            .filter(function (s) { return !!s; })
            .value();
    }

    function finalizeSageData(base) {
        var stats = rollStats();
        var finalAgeCategory = base.ageCategory || randomAgeCategory();
        var spellType = determineSpellType(base.majorField, base.specialCategories || [], base.spellTypeOverride);
        var maxSpellLevel = randomIntegerInclusive(1, 4) + 2;
        var spellCasterLevel = spellCasterLevelForMaxSpell(maxSpellLevel, spellType);
        var spellProfile = generateSpellLibrary(spellType, maxSpellLevel);
        var npcProfile = generateNpcProfileForSage(finalAgeCategory);
        return {
            id: makeSageId(),
            name: base.name,
            majorField: base.majorField,
            minorFields: base.minorFields || [],
            specialCategories: base.specialCategories || [],
            stats: stats,
            alignment: base.alignment || randomAlignment(),
            ageCategory: finalAgeCategory,
            npcProfile: npcProfile,
            hitPoints: rollHitPoints(stats.constitution),
            spellType: spellType,
            maxSpellLevel: maxSpellLevel,
            spellCasterLevel: spellCasterLevel,
            spellLibrary: spellProfile.library,
            preparedSpells: spellProfile.prepared,
            temporary: !!base.temporary,
            createdDay: state[STATE].currentDay,
            ownerId: '',
            ownerName: '',
            employment: 'available',
            salaryGp: 0,
            grantGp: 0,
            materialsGp: 0,
            efficiencyPct: 0,
            monthlyDueDay: 0,
            outsideFieldBonusPct: 0,
            minorFieldBonusPct: 0,
            activeStudy: null,
            shortTerm: null,
            cooldownUntilDay: 0,
            hireRoll: 0,
            salaryExpectationGp: 0,
            grantExpectationGp: 0,
            characterId: ''
        };
    }

    function buildCustomSage(args) {
        var major = resolveFieldKey(args.major);
        if (!major) return { error: 'Choose a valid major field.' };
        var minorKeys = [];
        if (args.minor1) minorKeys.push(resolveFieldKey(args.minor1));
        if (args.minor2) minorKeys.push(resolveFieldKey(args.minor2));
        if (!minorKeys.length) {
            minorKeys = _.chain(parseList(args.minors || args.minor || ''))
                .map(resolveFieldKey)
                .value();
        }
        minorKeys = _.chain(minorKeys)
            .filter(function (k) { return !!k && k !== major; })
            .uniq()
            .value();
        if (minorKeys.length !== 2) return { error: 'Custom sages must choose exactly two distinct minor fields.' };

        var specials = [];
        ['special1', 'special2', 'special3', 'special4'].forEach(function (key) {
            if (args[key]) specials.push(resolveSpecialForField(major, args[key]));
        });
        if (!specials.length) {
            specials = _.chain(parseList(args.specials || args.special || ''))
                .map(function (s) { return resolveSpecialForField(major, s); })
                .value();
        }
        specials = _.chain(specials).filter(function (s) { return !!s; }).uniq().value();
        if (specials.length !== 4) return { error: 'Custom sages must choose exactly four distinct special categories in the major field.' };

        return finalizeSageData({
            name: args.name || randomName(),
            majorField: major,
            minorFields: minorKeys,
            specialCategories: specials,
            temporary: normalizeText(args.temporary) === 'yes',
            alignment: args.alignment || randomAlignment(),
            ageCategory: args.agecategory || randomAgeCategory(),
            spellTypeOverride: args.spelltype || ''
        });
    }


