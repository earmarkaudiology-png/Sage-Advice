function buildHireQuote(employer, sage, kind, data) {
    data = data || {};
    return {
        id: makeHireQuoteId(),
        kind: kind,
        employerId: employer.id,
        employerName: employerName(employer),
        sageId: sage.id,
        sageName: sage.name,
        reactionBonus: getReactionBonus(employer.id),
        status: 'quote',
        haggleAttempts: 0,
        haggleFailures: 0,
        haggleDone: false,
        insulted: false,
        refused: false,
        currentCostGp: Math.max(0, parseInt(data.currentCostGp || 0, 10)),
        days: Math.max(0, parseInt(data.days || 0, 10)),
        salaryGp: Math.max(0, parseInt(data.salaryGp || 0, 10)),
        grantGp: Math.max(0, parseInt(data.grantGp || 0, 10)),
        materialsGp: Math.max(0, parseInt(data.materialsGp || 0, 10)),
        reactionRoll: data.reactionRoll || 0,
        favorable: !!data.favorable,
        salaryExpectationGp: Math.max(0, parseInt(data.salaryExpectationGp || 0, 10)),
        grantExpectationGp: Math.max(0, parseInt(data.grantExpectationGp || 0, 10)),
        linkedQuestionId: data.linkedQuestionId || ''
    };
}

