    function getSageById(id) {
        return _.find(state[STATE].sages, function (s) { return s.id === id; }) || null;
    }

    function allQuestions() {
        return state[STATE].questions;
    }

    function getQuestionById(id) {
        return _.find(allQuestions(), function (q) { return q.id === id; }) || null;
