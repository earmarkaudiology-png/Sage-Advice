    function determineSpellType(majorField, specialCategories, explicitType) {
        specialCategories = specialCategories || [];
        explicitType = normalizeText(explicitType || '');
        if (_.contains(['magic-user', 'illusionist', 'cleric', 'druid'], explicitType)) return explicitType;
        if (majorField === 'flora' || majorField === 'fauna') return 'druid';
        if (majorField === 'physical') return 'cleric';
        if (majorField === 'supernatural') {
            if (_.find(specialCategories, function (s) { return _.contains(SUPERNATURAL_MAGICUSER_SPECIALS, s); })) return 'magic-user';
            return 'illusionist';
        }
        if (majorField === 'humankind' || majorField === 'demihumankind' || majorField === 'humanoids') {
            if (_.find(specialCategories, function (s) { return _.contains(SPECIAL_CLERIC_OR_MAGICUSER, s); })) {
                return randomIntegerInclusive(1, 2) === 1 ? 'cleric' : 'magic-user';
            }
            return 'cleric';
        }
        return 'cleric';
    }

    function spellCasterLevelForMaxSpell(maxSpellLevel, spellType) {
        var map = {
            'magic-user': { 3: 5, 4: 7, 5: 9, 6: 11 },
            'illusionist': { 3: 5, 4: 7, 5: 9, 6: 11 },
            cleric: { 3: 5, 4: 7, 5: 9, 6: 11 },
            druid: { 3: 5, 4: 7, 5: 10, 6: 12 }
        };
        return (map[spellType] && map[spellType][maxSpellLevel]) || 5;
    }

    function generateSpellLibrary(spellType, maxSpellLevel) {
        var pool = SPELL_POOLS[spellType] || {};
        var library = {};
        var prepared = {};
        var lvl, available, chosen, count;
        for (lvl = 1; lvl <= maxSpellLevel; lvl += 1) {
            available = (pool[lvl] || []).slice();
            if (!available.length) continue;
            count = Math.min(available.length, randomIntegerInclusive(1, 4));
            chosen = chooseDistinct(available, count);
            library[lvl] = chosen;
            prepared[lvl] = chosen[randomIntegerInclusive(0, chosen.length - 1)];
        }
        return { library: library, prepared: prepared };
    }

    function formatSpellLibrary(spellLibrary) {
        return _.chain(_.keys(spellLibrary || {}))
            .sortBy(function (k) { return Number(k) || 0; })
            .map(function (k) { return 'L' + k + ': ' + (spellLibrary[k] || []).join(', '); })
            .value()
            .join(' | ');
    }

    function formatPreparedSpells(prepared) {
        return _.chain(_.keys(prepared || {}))
            .sortBy(function (k) { return Number(k) || 0; })
            .map(function (k) { return 'L' + k + ': ' + prepared[k]; })
            .value()
            .join(' | ');
    }

