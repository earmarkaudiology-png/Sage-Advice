    function handleHaggleQuestion(msg, args) {
        var employer = resolveEmployer(msg, args);
        var q = getQuestionById(args.question);
        var target;
        var roll;
        var success;
        var resultText;
        var buttons = '';
        if (!employer || !q || q.employerId !== employer.id) {
            send(box('Haggle Sage Price', 'Question quote not found for this employer.' + backMenuButton(employer ? employer.id : '')));
            return;
        }
        if (q.status !== 'quote') {
            send(box('Haggle Sage Price', '<div>This quote is no longer open for haggling.</div>' + backMenuButton(employer.id)));
            return;
        }
        if (q.haggleDone || (q.haggleAttempts || 0) >= 2) {
            send(box('Haggle Sage Price',
                line('Question', esc(q.question)) +
                '<div>No more haggle attempts remain for this quote.</div>' +
                backMenuButton(employer.id)
            ));
            return;
        }
        target = Math.max(0, Math.min(95, 10 + (Number(q.reactionBonus) || 0)));
        roll = randomIntegerInclusive(1, 100);
        success = roll <= target;
        q.haggleAttempts = (q.haggleAttempts || 0) + 1;
        if (success) {
            q.currentCostGp = Math.max(0, Math.round((Number(q.currentCostGp) || 0) * 0.95));
            q.haggleDone = true;
            resultText = '<span style="color:#8fe38f;font-weight:bold;">Success - sage reduces the quoted charge by 5%.</span>';
        } else {
            q.haggleFailures = (q.haggleFailures || 0) + 1;
            if ((q.haggleAttempts || 0) >= 2) {
                q.currentCostGp = Math.max(0, Math.round((Number(q.currentCostGp) || 0) * 1.10));
                q.haggleDone = true;
                resultText = '<span style="color:#ffb36b;font-weight:bold;">Second failure - the quoted charge increases by 10%.</span>';
            } else {
                resultText = '<span style="color:#ffb36b;font-weight:bold;">Failure - no change yet. One haggle attempt remains.</span>';
            }
        }
        if (q.status === 'quote') {
            buttons += '<div style="margin-top:8px;">' +
                menuBtn('Accept Quote / Pay', '!sage-accept-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.primaryBg, CONFIG.colors.primaryBorder, 140) +
                (!(q.haggleDone || (q.haggleAttempts || 0) >= 2) ? menuBtn('Haggle Price', '!sage-haggle-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) : '') +
                menuBtn('Deny Quote', '!sage-deny-question --pc|' + employer.id + ' --question|' + q.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 100) +
                '</div>';
        }
        send(box('Haggle Sage Price',
            line('Question', esc(q.question)) +
            line('Result', resultText) +
            line('Current Quote', esc((q.currentCostGp || 0) + ' gp')) +
            buttons +
            backMenuButton(employer.id)
        ));
    }

