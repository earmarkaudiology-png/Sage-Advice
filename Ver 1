    function randomIntegerInclusive(min, max) {
        return randomInteger(max - min + 1) + min - 1;
    }

    function randomPick(arr) {
        arr = arr || [];
        if (!arr.length) return '';
        return arr[randomInteger(arr.length) - 1];
    }

    function selectedCharacter(msg) {
        if (!msg.selected || !msg.selected.length) return null;
        var tok = getObj('graphic', msg.selected[0]._id);
        if (!tok) return null;
        var charId = tok.get('represents');
        if (!charId) return null;
        return getObj('character', charId);
    }

    function resolveEmployer(msg, args) {
        var ch = selectedCharacter(msg);
        if (ch) return ch;
        if (args.pc) return getObj('character', args.pc);
        return null;
    }

    function employerName(ch) {
        return ch ? (ch.get('name') || 'Employer') : 'Employer';
    }

    function getAttrObj(charId, name) {
        var obj = findObjs({ type: 'attribute', characterid: charId, name: name })[0];
        if (!obj) obj = createObj('attribute', { characterid: charId, name: name, current: 0 });
        return obj;
    }

    function getAttr(charId, name, defVal) {
        var obj = findObjs({ type: 'attribute', characterid: charId, name: name })[0];
        if (!obj) return defVal;
        var v = obj.get('current');
        return v === '' || v === undefined || v === null ? defVal : v;
    }

    function setAttr(charId, name, val) {
        getAttrObj(charId, name).set('current', val);
    }

    function coinSummary(charId) {
        return {
            gp: Number(getAttr(charId, CONFIG.coinAttrs.gp, 0)) || 0,
            sp: Number(getAttr(charId, CONFIG.coinAttrs.sp, 0)) || 0,
            cp: Number(getAttr(charId, CONFIG.coinAttrs.cp, 0)) || 0
        };
    }

    function cpTotal(charId) {
        var c = coinSummary(charId);
        return (c.gp * 100) + (c.sp * 10) + c.cp;
    }

    function gpToCp(gp) {
        return Math.round((Number(gp) || 0) * 100);
    }

    function formatCoinsFromCp(totalCp) {
        totalCp = Math.max(0, Math.floor(totalCp || 0));
        var gp = Math.floor(totalCp / 100);
        var rem = totalCp % 100;
        var sp = Math.floor(rem / 10);
        var cp = rem % 10;
        var out = [];
        if (gp) out.push(gp + ' gp');
        if (sp) out.push(sp + ' sp');
        if (cp || !out.length) out.push(cp + ' cp');
        return out.join(', ');
    }

    function deductCoins(charId, cpCost) {
        cpCost = Math.max(0, Math.floor(cpCost || 0));
        var total = cpTotal(charId);
        if (total < cpCost) return false;
        var remain = total - cpCost;
        setAttr(charId, CONFIG.coinAttrs.gp, Math.floor(remain / 100));
        setAttr(charId, CONFIG.coinAttrs.sp, Math.floor((remain % 100) / 10));
        setAttr(charId, CONFIG.coinAttrs.cp, remain % 10);
        return true;
    }

    function getReactionBonus(charId) {
        return Number(getAttr(charId, CONFIG.reactionAttr, 0)) || 0;
    }

