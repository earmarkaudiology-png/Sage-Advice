    function processMonthlyCosts(months) {
        _.each(_.filter(allSages(), function (s) { return s.employment === 'permanent'; }), function (sage) {
            sage.monthlyDueDay += months * CONFIG.daysPerMonth;
        });
    }

    function processStudies(days) {
        _.each(allSages(), function (sage) {
            if (!sage.activeStudy) return;
            if (sage.activeStudy.endDay > state[STATE].currentDay) return;
            var study = sage.activeStudy;
            if (study.kind === 'outsidebonus') {
                sage.outsideFieldBonusPct = Math.min(5, (Number(sage.outsideFieldBonusPct) || 0) + 1);
            } else if (study.kind === 'minorbonus') {
                sage.minorFieldBonusPct = Math.min(5, (Number(sage.minorFieldBonusPct) || 0) + 1);
            } else if (study.kind === 'addminor') {
                if (!_.contains(sage.minorFields, study.fieldKey) && sage.minorFields.length < 3) sage.minorFields.push(study.fieldKey);
            } else if (study.kind === 'addmajor') {
                if (!_.contains(sage.minorFields, study.fieldKey) && sage.majorField !== study.fieldKey) {
                    if (sage.minorFields.length < 3) sage.minorFields.push(study.fieldKey);
                }
            }
            sage.activeStudy = null;
            updateCharacterForSage(sage);
            sendGM(box('Sage Study Complete', line('Sage', esc(sage.name)) + line('Completed', esc(study.label))));
        });
    }

