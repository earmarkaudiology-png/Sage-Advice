    function sageKnowledgeSummary(sage) {
    var parts = [];
    parts.push('Major Field: ' + labelForField(sage.majorField));
    if (sage.specialCategories && sage.specialCategories.length) {
        parts.push('Special Categories: ' + sage.specialCategories.join(', '));
    }
    if (sage.minorFields && sage.minorFields.length) {
        parts.push('Minor Fields: ' + _.map(sage.minorFields, labelForField).join(', '));
    }
    return parts.join(' | ');
}

